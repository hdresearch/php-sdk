{
    "name": "vers/sdk",
    "description": "Orchestrator Control Plane API - PHP SDK",
    "version": "0.1.8",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "VersSdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VersSdk\\Tests\\": "tests/"
        }
    }
}
